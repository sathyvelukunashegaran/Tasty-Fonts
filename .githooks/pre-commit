#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"

cd "$ROOT_DIR"

if [[ "${TASTY_FONTS_SKIP_ARTIFACT_CLEANUP_HOOK:-0}" != "1" ]]; then
  echo "Cleaning generated local artifacts..."
  bin/clean-artifacts --quiet
fi

if [[ ! -x vendor/bin/phpstan ]]; then
  echo "PHPStan is required for commits. Run 'composer install' to install the repo dev tooling." >&2
  exit 1
fi

echo "Running PHPStan..."

composer phpstan

if [[ -x node_modules/.bin/stylelint ]]; then
  echo "Running Stylelint..."
  npm run lint:css
else
  echo "Skipping Stylelint because npm dependencies are not installed. Run 'npm ci' to enable CSS linting locally."
fi

if [[ "${TASTY_FONTS_SKIP_JSCPD_HOOK:-0}" == "1" ]]; then
  exit 0
fi

echo "Running jscpd duplicate scan..."

bin/run-jscpd

if [[ "${TASTY_FONTS_SKIP_ARTIFACT_CLEANUP_HOOK:-0}" != "1" ]]; then
  echo "Cleaning generated local artifacts..."
  bin/clean-artifacts --quiet
fi
