#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$ROOT_DIR"

shopt -s nullglob

paths=(
  ".playwright-cli"
  ".playwright-mcp"
  "output"
  "tmp"
  "report"
  "prompt-exports"
  kicker-*.png
  masthead-warmer.png
  neutral-bg.png
  three-color-*.png
)

removed=0

for path in "${paths[@]}"; do
  if [[ -e "$path" || -L "$path" ]]; then
    rm -rf "$path"
    removed=1
  fi
done

while IFS= read -r -d '' path; do
  rm -f "$path"
  removed=1
done < <(find . \
  \( -path './.git' -o -path './vendor' -o -path './node_modules' \) -prune \
  -o -name '.DS_Store' -print0)

if [[ "${1:-}" != "--quiet" ]]; then
  if [[ "$removed" == "1" ]]; then
    echo "Cleaned generated local artifacts."
  else
    echo "No generated local artifacts found."
  fi
fi
