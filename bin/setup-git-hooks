#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ ! -d "$ROOT_DIR/.git" ]]; then
  echo "This script must be run from a git checkout." >&2
  exit 1
fi

git -C "$ROOT_DIR" config core.hooksPath .githooks

echo "Configured core.hooksPath to .githooks"
