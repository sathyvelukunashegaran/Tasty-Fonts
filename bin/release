#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  bin/release beta <X.Y.Z-beta.N> [--no-push]
  bin/release stable <X.Y.Z> [--no-push]

Commands:
  beta    Cut a beta release tag from main.
  stable  Cut a stable release tag from main, then advance main to the next minor X.Y.Z-dev line.
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

command_name="${1:-}"
version=""
push_release=true

shift $(( $# > 0 ? 1 : 0 )) || true

for arg in "$@"; do
  case "$arg" in
    --no-push)
      push_release=false
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [[ -z "$version" ]]; then
        version="$arg"
      else
        die "Unexpected argument: $arg"
      fi
      ;;
  esac
done

[[ -n "$command_name" ]] || {
  usage >&2
  exit 1
}

[[ -n "$version" ]] || {
  usage >&2
  exit 1
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
cd "$repo_root"

set_version_script="${script_dir}/set-version"
promote_changelog_script="${script_dir}/promote-changelog"

current_branch() {
  git branch --show-current
}

ensure_clean_worktree() {
  git diff --quiet || die "Working tree has unstaged changes."
  git diff --cached --quiet || die "Index has staged changes."
}

validate_stable_version() {
  [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || die "Stable versions must use X.Y.Z format."
}

validate_beta_version() {
  [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+-beta\.[0-9]+$ ]] || die "Beta versions must use X.Y.Z-beta.N format."
}

release_line_from_version() {
  php -r '
    $version = $argv[1];
    if (preg_match("/^([0-9]+)\.([0-9]+)\.[0-9]+(?:-.+)?$/", $version, $matches) !== 1) {
        fwrite(STDERR, "Could not derive release line from version\n");
        exit(1);
    }
    echo $matches[1] . "." . $matches[2];
  ' "$1"
}

current_plugin_version() {
  sed -n 's/^Version: //p' plugin.php | head -n 1 | tr -d '\r'
}

ensure_matching_release_line_on_main() {
  local target_version="$1"
  local current_version
  local target_line
  local current_line

  [[ "$(current_branch)" == "main" ]] || die "Releases must be cut from main."

  current_version="$(current_plugin_version)"
  [[ "$current_version" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-beta\.[0-9]+|-dev(\.[0-9]+)?)$ ]] || \
    die "main must be on an X.Y.Z-dev or X.Y.Z-beta.N version before promoting ${target_version}. Found ${current_version}."

  target_line="$(release_line_from_version "$target_version")"
  current_line="$(release_line_from_version "$current_version")"
  [[ "$current_line" == "$target_line" ]] || \
    die "main is on ${current_version}; expected the ${target_line}.x line before promoting ${target_version}."
}

tag_exists_anywhere() {
  local tag_name="$1"

  git rev-parse -q --verify "refs/tags/${tag_name}" >/dev/null && return 0

  if $push_release; then
    local remote_tag_refs
    remote_tag_refs="$(git ls-remote --tags origin "refs/tags/${tag_name}" "refs/tags/${tag_name}^{}")"
    [[ -n "$remote_tag_refs" ]] && return 0
  fi

  return 1
}

run_quality_gates() {
  if [[ -f composer.json && -x vendor/bin/phpstan ]]; then
    composer phpstan
  fi

  find . -name '*.php' -not -path './output/*' -not -path './tmp/*' -not -path './vendor/*' -print0 | xargs -0 -n1 php -l >/dev/null
  php tests/run.php
  node --test tests/js/*.test.cjs
  bash tests/bin/release-scripts.test.sh
}

next_dev_version_after_stable() {
  php -r '
    $version = $argv[1];
    if (preg_match("/^([0-9]+)\.([0-9]+)\.([0-9]+)$/", $version, $matches) !== 1) {
        fwrite(STDERR, "Stable version must use X.Y.Z format\n");
        exit(1);
    }
    echo $matches[1] . "." . ((int) $matches[2] + 1) . ".0-dev";
  ' "$1"
}

commit_and_tag_release() {
  local target_version="$1"

  tag_exists_anywhere "$target_version" && die "Tag ${target_version} already exists."

  "$set_version_script" "$target_version"
  "$promote_changelog_script" "$target_version"
  run_quality_gates

  git add plugin.php CHANGELOG.md
  git commit -m "Release ${target_version}"
  git tag -a "${target_version}" -m "Release ${target_version}"
}

advance_main_to_next_dev() {
  local stable_version="$1"
  local next_dev_version

  next_dev_version="$(next_dev_version_after_stable "$stable_version")"
  "$set_version_script" "$next_dev_version"
  git add plugin.php
  git commit -m "Start ${next_dev_version}"
}

push_main_and_tag() {
  local target_version="$1"

  if $push_release; then
    git push origin main
    git push origin "${target_version}"
    echo "Released ${target_version} from main."
  else
    echo "Prepared ${target_version} locally on main without pushing."
  fi
}

cut_beta_release() {
  local beta_version="$1"

  validate_beta_version "$beta_version"
  ensure_matching_release_line_on_main "$beta_version"
  commit_and_tag_release "$beta_version"
  push_main_and_tag "$beta_version"
}

cut_stable_release() {
  local stable_version="$1"

  validate_stable_version "$stable_version"
  ensure_matching_release_line_on_main "$stable_version"
  commit_and_tag_release "$stable_version"
  advance_main_to_next_dev "$stable_version"
  push_main_and_tag "$stable_version"
}

case "$command_name" in
  beta)
    ensure_clean_worktree
    cut_beta_release "$version"
    ;;
  stable)
    ensure_clean_worktree
    cut_stable_release "$version"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
