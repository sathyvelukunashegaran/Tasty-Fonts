#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  bin/release branch <X.Y.Z> [--no-push]
  bin/release beta <X.Y.Z-beta.N> [--no-push]
  bin/release stable <X.Y.Z> [--no-push]

Commands:
  branch  Create release/X.Y from main at the current dev state, set the branch to X.Y.Z-beta.1, and leave main unchanged.
  beta    Cut a beta release by promoting the current dev state on main into release/X.Y, or tag the current release/X.Y branch.
  stable  Cut a stable release from release/X.Y, promoting the changelog and tagging the version.
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

command_name="${1:-}"
version=""
push_release=true

shift $(( $# > 0 ? 1 : 0 )) || true

for arg in "$@"; do
  case "$arg" in
    --no-push)
      push_release=false
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [[ -z "$version" ]]; then
        version="$arg"
      else
        die "Unexpected argument: $arg"
      fi
      ;;
  esac
done

[[ -n "$command_name" ]] || {
  usage >&2
  exit 1
}

[[ -n "$version" ]] || {
  usage >&2
  exit 1
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
cd "$repo_root"

set_version_script="${script_dir}/set-version"
promote_changelog_script="${script_dir}/promote-changelog"

current_branch() {
  git branch --show-current
}

ensure_clean_worktree() {
  git diff --quiet || die "Working tree has unstaged changes."
  git diff --cached --quiet || die "Index has staged changes."
}

validate_stable_version() {
  [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || die "Stable versions must use X.Y.Z format."
}

validate_beta_version() {
  [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+-beta\.[0-9]+$ ]] || die "Beta versions must use X.Y.Z-beta.N format."
}

release_line_from_version() {
  php -r '
    $version = $argv[1];
    if (preg_match("/^([0-9]+)\.([0-9]+)\.[0-9]+(?:-.+)?$/", $version, $matches) !== 1) {
        fwrite(STDERR, "Could not derive release line from version\n");
        exit(1);
    }
    echo $matches[1] . "." . $matches[2];
  ' "$1"
}

current_plugin_version() {
  sed -n 's/^Version: //p' plugin.php | head -n 1 | tr -d '\r'
}

ensure_matching_dev_base_on_main() {
  local target_version="$1"
  local current_version
  local target_line
  local current_line

  current_version="$(current_plugin_version)"
  [[ "$current_version" =~ ^[0-9]+\.[0-9]+\.[0-9]+-dev(\.[0-9]+)?$ ]] || \
    die "main must be on an X.Y.Z-dev version before promoting ${target_version}. Found ${current_version}."

  target_line="$(release_line_from_version "$target_version")"
  current_line="$(release_line_from_version "$current_version")"
  [[ "$current_line" == "$target_line" ]] || \
    die "main is on ${current_version}; expected the ${target_line}.x dev line before promoting ${target_version}."
}

ensure_release_branch_missing() {
  local branch_name="$1"

  git show-ref --verify --quiet "refs/heads/${branch_name}" && \
    die "Branch ${branch_name} already exists locally."

  if $push_release; then
    git ls-remote --exit-code --heads origin "${branch_name}" >/dev/null 2>&1 && \
      die "Branch ${branch_name} already exists on origin."
  fi
}

tag_exists_anywhere() {
  local tag_name="$1"

  git rev-parse -q --verify "refs/tags/${tag_name}" >/dev/null && return 0

  if $push_release; then
    local remote_tag_refs
    remote_tag_refs="$(git ls-remote --tags origin "refs/tags/${tag_name}" "refs/tags/${tag_name}^{}")"
    [[ -n "$remote_tag_refs" ]] && return 0
  fi

  return 1
}

run_quality_gates() {
  find . -name '*.php' -not -path './output/*' -print0 | xargs -0 -n1 php -l >/dev/null
  php tests/run.php
  node --test tests/js/*.test.cjs
  bash tests/bin/release-scripts.test.sh
}

commit_and_tag_release() {
  local target_version="$1"
  local branch_name="$2"

  tag_exists_anywhere "$target_version" && die "Tag ${target_version} already exists."

  "$set_version_script" "$target_version"
  "$promote_changelog_script" "$target_version"
  run_quality_gates

  git add plugin.php CHANGELOG.md
  git commit -m "Release ${target_version}"
  git tag -a "${target_version}" -m "Release ${target_version}"

  if $push_release; then
    git push origin "${branch_name}"
    git push origin "${target_version}"
    echo "Released ${target_version} from ${branch_name}."
  else
    echo "Prepared ${target_version} locally on ${branch_name} without pushing."
  fi
}

cut_release_branch() {
  local stable_version="$1"
  local branch_name="release/$(release_line_from_version "$stable_version")"
  local beta_version="${stable_version}-beta.1"

  validate_stable_version "$stable_version"
  [[ "$(current_branch)" == "main" ]] || die "Release branch cuts must start from main."
  ensure_matching_dev_base_on_main "$stable_version"
  ensure_release_branch_missing "$branch_name"

  git switch -c "${branch_name}"
  "$set_version_script" "$beta_version"
  git add plugin.php
  git commit -m "Start ${branch_name} beta line"

  if $push_release; then
    git push origin "${branch_name}"
    echo "Created ${branch_name} at ${beta_version} from the current main dev state."
  else
    echo "Created ${branch_name} at ${beta_version} locally from the current main dev state without pushing."
  fi
}

cut_beta_release() {
  local beta_version="$1"
  local branch_name="release/$(release_line_from_version "$beta_version")"
  local current_branch_name

  validate_beta_version "$beta_version"
  current_branch_name="$(current_branch)"

  if [[ "$current_branch_name" == "main" ]]; then
    ensure_matching_dev_base_on_main "$beta_version"
    ensure_release_branch_missing "$branch_name"
    git switch -c "${branch_name}"
    commit_and_tag_release "$beta_version" "$branch_name"
    return
  fi

  [[ "$current_branch_name" == "$branch_name" ]] || die "Beta releases must be cut from main or ${branch_name}."
  commit_and_tag_release "$beta_version" "$branch_name"
}

case "$command_name" in
  branch)
    ensure_clean_worktree
    cut_release_branch "$version"
    ;;
  beta)
    ensure_clean_worktree
    cut_beta_release "$version"
    ;;
  stable)
    ensure_clean_worktree
    validate_stable_version "$version"
    branch_name="release/$(release_line_from_version "$version")"
    [[ "$(current_branch)" == "$branch_name" ]] || die "Stable releases must be cut from ${branch_name}."
    commit_and_tag_release "$version" "$branch_name"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
