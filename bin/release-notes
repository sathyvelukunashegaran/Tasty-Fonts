#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: bin/release-notes <version>

Prints the matching version section from CHANGELOG.md without the version heading.
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

version="${1:-}"

if [[ -z "${version}" || "${version}" == "-h" || "${version}" == "--help" ]]; then
  usage
  [[ -n "${version}" ]] && exit 0
  exit 1
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
cd "${repo_root}"

php -r '
  $version = $argv[1];
  $contents = file_get_contents("CHANGELOG.md");

  if ($contents === false) {
      fwrite(STDERR, "Could not read CHANGELOG.md\n");
      exit(1);
  }

  $extractSection = static function (string $targetVersion) use ($contents): ?string {
      $pattern = "/^## \\[" . preg_quote($targetVersion, "/") . "\\](?: - [^\r\n]*)?\\R(.*?)(?=^## \\[|\\z)/ms";

      if (!preg_match($pattern, $contents, $matches)) {
          return null;
      }

      $notes = trim($matches[1]);

      return $notes === "" ? "" : $notes;
  };

  $notes = $extractSection($version);

  if ($notes === null) {
      fwrite(STDERR, "Could not find CHANGELOG.md section for " . $version . "\n");
      exit(1);
  }

  if ($notes === "") {
      fwrite(STDERR, "CHANGELOG.md section for " . $version . " is empty\n");
      exit(1);
  }

  if (preg_match("/^[0-9]+\\.[0-9]+\\.[0-9]+$/", $version) === 1) {
      $nonEmptyLines = array_values(array_filter(
          preg_split("/\\R/", $notes) ?: [],
          static fn (string $line): bool => trim($line) !== ""
      ));
      $bodyLines = array_values(array_filter(
          $nonEmptyLines,
          static fn (string $line): bool => preg_match("/^###\\s+/", $line) !== 1
      ));
      $isPromotionOnly = count($bodyLines) === 1 && preg_match("/^-\\s+Promoted\\b/i", $bodyLines[0]) === 1;

      if ($isPromotionOnly) {
          $betaPattern = "/^## \\[" . preg_quote($version, "/") . "-beta\\.([0-9]+)\\](?: - [^\r\n]*)?\\R(.*?)(?=^## \\[|\\z)/ms";
          $betaMatches = [];

          if (preg_match_all($betaPattern, $contents, $betaMatches, PREG_SET_ORDER) > 0) {
              usort(
                  $betaMatches,
                  static fn (array $left, array $right): int => (int) $left[1] <=> (int) $right[1]
              );

              foreach ($betaMatches as $betaMatch) {
                  $betaNotes = trim($betaMatch[2]);

                  if ($betaNotes !== "") {
                      $notes .= "\n\n" . $betaNotes;
                  }
              }
          }
      }
  }

  echo $notes . PHP_EOL;
  ' "$version"
